<UserControl
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:vm="using:DailyFortune.ViewModels"
	x:Class="DailyFortune.Views.HistoryView"
	x:DataType="vm:HistoryViewModel">

  <Border Background="#FFF" CornerRadius="8" Padding="8" Width="320" MaxHeight="400" Opacity="0.95">
	<StackPanel>
	  <TextBlock Text="History" FontSize="18" FontWeight="Bold" Margin="6"/>

		<ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
		<ItemsControl ItemsSource="{Binding Items}">
		  <ItemsControl.ItemTemplate>
			<DataTemplate x:DataType="vm:HistoryItemViewModel">
			  <Border Padding="6" Margin="4" CornerRadius="6" Background="#FFF8">
				<StackPanel Orientation="Horizontal" Spacing="8">
				  <Image Source="{Binding Image}" Width="48" Height="48"/>
				  <StackPanel Orientation="Vertical">
					<TextBlock Text="{Binding Text}" TextWrapping="Wrap" FontSize="12" MaxWidth="220"/>
					<TextBlock Text="{Binding OpenedDate, StringFormat='Opened: {0:g}'}" FontSize="10" Foreground="#666"/>
				  </StackPanel>
				</StackPanel>
			  </Border>
			</DataTemplate>
		  </ItemsControl.ItemTemplate>
		</ItemsControl>
	  </ScrollViewer>
	</StackPanel>
  </Border>

</UserControl>
