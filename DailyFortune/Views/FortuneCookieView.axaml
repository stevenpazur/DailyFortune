<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:DailyFortune.ViewModels"
    x:Class="DailyFortune.Views.FortuneCookieView"
    x:DataType="vm:FortuneCookieViewModel">

  <StackPanel
      HorizontalAlignment="Center"
      VerticalAlignment="Center"
      Spacing="30">

    <TextBlock
        Text="🥠 Daily Fortune"
        FontSize="32"
        HorizontalAlignment="Center"/>

    <Border
        Width="300"
        Height="180"
        Background="White"
        CornerRadius="90">

      <Image
          Width="128"
          Height="128"
          Source="{Binding CookieImage}"
          HorizontalAlignment="Center"
          VerticalAlignment="Center"/>

    </Border>

    <TextBlock
        Text="{Binding CurrentFortune.Text}"
        FontSize="20"
        Width="350"
        TextWrapping="Wrap"
        TextAlignment="Center"/>

    <Button
        Content="Open Cookie"
        Command="{Binding OpenCookieCommand}"
        FontSize="18"/>

  </StackPanel>

</UserControl>