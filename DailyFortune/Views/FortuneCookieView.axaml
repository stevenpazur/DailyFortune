<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:DailyFortune.ViewModels"
    x:Class="DailyFortune.Views.FortuneCookieView"
    x:DataType="vm:FortuneCookieViewModel">

  <StackPanel
      HorizontalAlignment="Center"
      VerticalAlignment="Center"
      Spacing="30">

    <TextBlock
        Text="🥠 Daily Fortune"
        FontSize="32"
        HorizontalAlignment="Center"/>

    <Border
        Width="300"
        Height="180"
        Background="White"
        CornerRadius="90">

        <!-- Grid holds the interactive button and a still opened image overlay -->
        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">

          <!-- Button shown during reset/interactive state; disabled when CanOpen is false -->
          <Button
            Command="{Binding OpenCookieCommand}"
            Background="Transparent"
            Cursor="Hand"
            BorderThickness="0"
            Padding="0"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            IsEnabled="{Binding CanOpen}">
            <Image
                Width="128"
                Height="128"
                Source="{Binding CookieImage}">

              <Image.RenderTransform>
                <RotateTransform
                    Angle="{Binding CookieRotation}"/>
              </Image.RenderTransform>

            </Image>
          </Button>

          <!-- Static opened image that appears when cookie has been opened -->
          <Image
              Width="128"
              Height="128"
              Source="{Binding CookieImage}"
              IsVisible="{Binding IsOpened}"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"/>

        </Grid>

    </Border>

    <TextBlock
        Text="{Binding FortuneText}"
        FontSize="20"
        Width="350"
        TextWrapping="Wrap"
        TextAlignment="Center"/>

  </StackPanel>

</UserControl>